<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/greenLight">

    <!-- Wrapper to center everything -->
    <LinearLayout
        android:padding="10dp"
        android:id="@+id/mainContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="16dp">

        <!-- Header Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/headerCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            android:padding="10dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/greenPrimary">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_gravity="center"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Profile Settings"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_gravity="center"
                    android:id="@+id/email"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="user@email.com"
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:alpha="0.9"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Space between cards -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="16dp"/>

        <!-- Main Content Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Username"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/greenPrimaryDark"
                    android:layout_marginBottom="8dp"/>

                <EditText
                    android:layout_margin="10dp"
                    android:id="@+id/edtUsername"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="Enter your username"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="@color/textDark"
                    android:textSize="16sp"
                    android:background="@drawable/edittext_background"
                    android:layout_marginBottom="24dp"/>

                <Button
                    android:layout_margin="8dp"
                    android:id="@+id/btnUpdateUsername"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Update Username"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:backgroundTint="@color/greenPrimary"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:layout_margin="8dp"
                    android:id="@+id/btnShare"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Share My Location"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:backgroundTint="@color/greenAccent"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:layout_margin="8dp"
                    android:id="@+id/btnMap"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="View on Map"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:backgroundTint="@color/greenPrimaryDark"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>